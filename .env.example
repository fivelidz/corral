# ── Corral environment variables ─────────────────────────────────────────────
# Copy this to .env and fill in your values.
# .env is gitignored — never commit real keys.

# ── Supabase (required for real auth + data) ──────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
# Without these the app runs in demo mode with mock data — that's fine for testing.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Agent endpoint (optional) ─────────────────────────────────────────────────
# URL of the Claude agent HTTP endpoint for the in-app chat.
# Without this the Agent tab uses scripted demo responses.
# When you build the real agent: set this to http://superlocal:PORT/chat or similar.
VITE_AGENT_URL=

# ── Notion (scripts only, never exposed to browser) ──────────────────────────
# Used by scripts/notion_full_update.py and scripts/notion_poll_feedback.py
# Get from: notion.so/my-integrations → corral dev integration
# Run: NOTION_TOKEN=ntn_xxx python3 scripts/notion_full_update.py
NOTION_TOKEN=
